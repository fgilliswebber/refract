@prefix fract: <https://w3id.org/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix vo: <http://purl.obolibrary.org/obo/> .
@prefix ex: <https://example.org/vo/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

fract:tmf_ec3 a fract:Manifest ;
    rdfs:label "Manifest 1.0.0 for evolution of Vaccine Ontology"@en ;
    fract:transformationType fract:OntologyEvolutionProcess ;
    fract:transformationSource <http://purl.obolibrary.org/obo/vo.owl> ;
    fract:hasURIRelationshipToSource fract:SameVersionedRelationship ;
    fract:versionManifest fract:tmf_ec3_v1 ;
    dash:shape shape:ShapeEvolution ;
    fract:hasAction fract:action_ec3_1, fract:action_ec3_2, fract:action_ec3_3, fract:action_ec3_4, fract:action_ec3_5 ;
    fract:actionOrder (
        fract:action_ec3_1
        fract:action_ec3_2
        fract:action_ec3_3
        fract:action_ec3_4
        fract:action_ec3_5
    ) .

fract:tmf_ec3_v1 a fract:Version ;
    fract:versionNumber "1.0.0" ;
    dct:date "2025-05-01" ;
    fract:versionPrevious fract:NoPreviousVersion ;
    dct:contributor "Frances Gillis-Webber" .

fract:action_ec3_1 a fract:AddClass ;
    fract:targetIdentifier ex:mRNAVaccine ;
    fract:targetParent vo:VO_0000001 ;
    fract:targetLabel "mRNA vaccine" ;
    fract:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddClass .

fract:action_ec3_2 a fract:AddSuperclassAssertion ;
    fract:sourceNode vo:VO_0005198 ;
    fract:targetParent ex:mRNAVaccine ;
    dash:shape shape:ShapeAddSuperclassAssertion .

fract:action_ec3_3 a fract:AddPropertyRestriction ;
    fract:targetNode ex:mRNAVaccine ;
    fract:targetObject vo:RO_0000087 ;
    fract:targetObjectValue vo:VO_0000728 ;
    fract:restrictionType owl:someValuesFrom ;
    fract:propertyType owl:ObjectProperty ;
    dash:shape shape:ShapeAddPropertyRestriction .

fract:action_ec3_4 a fract:AddAnnotationLangString ;
    fract:targetNode ex:mRNAVaccine ;
    fract:targetAnnotation skos:definition ;
    fract:targetAnnotationValue "A vaccine that uses messenger RNA (mRNA) technology to instruct cells to produce a protein that triggers an immune response." ;
    fract:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddAnnotationLangString .

fract:action_ec3_5 a fract:AddInstance ;
    fract:targetIdentifier ex:PfizerBioNTech ;
    fract:targetInstanceOf ex:mRNAVaccine ;
    fract:targetLabel "Pfizer-BioNTech COVID-19 vaccine" ;
    fract:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddInstance .
