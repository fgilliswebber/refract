mesh:D007391 a owl:Class ;
    rdfs:label "International Cooperation"@en .

mesh:D005062 a owl:Class ;
    skos:prefLabel "European Union"@en ;
    rdfs:subClassOf mesh:D007391 ;
    skos:definition "An economic union with the principal objectives of free movement of goods, capital, and labor. The constituent countries are Austria, Belgium, Bulgaria, Croatia, Cyprus, Czech Republic, Denmark, Estonia, Finland, France, Germany, Greece, Hungary, Ireland, Italy, Latvia, Lithuania, Luxembourg, Malta, Netherlands, Poland, Portugal, Romania, Slovakia, Slovenia, Spain, and Sweden. (https://europa.eu/european-union/about-eu/countries accessed 31/01/2020)"@en ;
    skos:historyNote "The United Kingdom was a member of the European Union until 31 January 2020, when it formally withdrew following the Brexit referendum of 23 June 2016."@en ;
    dct:modified "2020-01-31"^^xsd:date .