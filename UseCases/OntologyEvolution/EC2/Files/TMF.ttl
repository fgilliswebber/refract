@prefix fract: <https://w3id.org/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix mesh: <http://purl.bioontology.org/ontology/MESH/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

fract:tmf_ec2 a fract:Manifest ;
    rdfs:label "Manifest 1.0.0 for evolution of MeSH ontology"@en ;
    fract:transformationType fract:OntologyEvolutionProcess ;
    fract:transformationSource <http://purl.bioontology.org/ontology/MESH/> ;
    fract:hasURIRelationshipToSource fract:SameVersionedRelationship ;
    fract:versionManifest fract:tmf_ec2_v1 ;
    dash:shape shape:ShapeEvolution ;
    fract:hasAction fract:action_ec2_1, fract:action_ec2_2, fract:action_ec2_3 ;
    fract:actionOrder (
        fract:action_ec2_1
        fract:action_ec2_2
        fract:action_ec2_3
    ) .

fract:tmf_ec2_v1 a fract:Version ;
    fract:versionNumber "1.0.0" ;
    dct:date "2025-05-01" ;
    fract:versionPrevious fract:NoPreviousVersion ;
    dct:contributor "Frances Gillis-Webber" .

fract:action_ec2_1 a fract:ChangeAnnotationValue ;
    fract:sourceNode mesh:D005062 ;
    fract:targetAnnotation skos:definition ;
    fract:targetAnnotationValue "An economic union with the principal objectives of free movement of goods, capital, and labor. The constituent countries are Austria, Belgium, Bulgaria, Croatia, Cyprus, Czech Republic, Denmark, Estonia, Finland, France, Germany, Greece, Hungary, Ireland, Italy, Latvia, Lithuania, Luxembourg, Malta, Netherlands, Poland, Portugal, Romania, Slovakia, Slovenia, Spain, and Sweden. (https://europa.eu/european-union/about-eu/countries accessed 31/01/2020)" ;
    fract:targetLanguageTag "en" ;
    dash:shape shape:ShapeChangeAnnotationValue .

fract:action_ec2_2 a fract:AddAnnotationLangString ;
    fract:sourceNode mesh:D005062 ;
    fract:targetAnnotation skos:historyNote ;
    fract:targetAnnotationValue "The United Kingdom was a member of the European Union until 31 January 2020, when it formally withdrew following the Brexit referendum of 23 June 2016." ;
    fract:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddAnnotationLangString .

fract:action_ec2_3 a fract:AddAnnotation ;
    fract:sourceNode mesh:D005062 ;
    fract:targetAnnotation dct:modified ;
    fract:targetAnnotationValue "2020-01-31" ;
    fract:targetDataType xsd:date ;
    dash:shape shape:ShapeAddAnnotation .
