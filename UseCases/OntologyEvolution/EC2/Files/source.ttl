    rdfs:label "International Cooperation"@en .

mesh:D005062 a owl:Class ;
    skos:prefLabel "European Union"@en ;
    rdfs:subClassOf mesh:D007391 ;
    skos:definition "An economic union with the principal objectives of free movement of goods, capital, and labor. The constituent countries are Austria, Belgium, Bulgaria, Croatia, Cyprus, Czech Republic, Denmark, Estonia, Finland, France, Germany, Greece, Hungary, Ireland, Italy, Latvia, Lithuania, Luxembourg, Malta, Netherlands, Poland, Portugal, Romania, Slovakia, Slovenia, Spain, Sweden, and United Kingdom. (https://europa.eu/european-union/about-eu/countries accessed 12/31/2020)"@en .