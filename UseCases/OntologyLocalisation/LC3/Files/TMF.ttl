@prefix fract: <https://w3id.org/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix mar: <https://example.org/marine#> .
@prefix marnz: <https://example.org/marine/nz#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

fract:tmf_lc3 a fract:Manifest ;
    rdfs:label "Manifest 1.0.0 for localisation of Marine Life Ontology to New Zealand Viewpoint"@en ;
    fract:transformationType fract:OntologyLocalisationProcess ;
    fract:transformationSource <https://example.org/marine> ;
    fract:hasURIRelationshipToSource fract:DifferentRelationship ;
    fract:targetOntologyURI <https://example.org/marine/nz> ;
    fract:targetViewpoint <https://semanticweb.tools/rdf/multi/newzealand> ;
    fract:versionManifest fract:tmf_lc3_v1 ;
    dash:shape shape:ShapeLocalisation ;
    fract:hasAction fract:action_lc3_1, fract:action_lc3_2, fract:action_lc3_3,
                  fract:action_lc3_4, fract:action_lc3_5 ;
    fract:actionOrder (
        fract:action_lc3_1
        fract:action_lc3_2
        fract:action_lc3_3
        fract:action_lc3_4
        fract:action_lc3_5
    ) .

fract:tmf_lc3_v1 a fract:Version ;
    fract:versionNumber "1.0.0" ;
    dct:date "2025-05-01" ;
    fract:versionPrevious fract:NoPreviousVersion ;
    dct:contributor "Frances Gillis-Webber" .

fract:action_lc3_1 a fract:AddObjectProperty ;
    fract:targetIdentifier marnz:hasGuardian ;
    fract:targetLabel "has guardian" ;
    fract:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddObjectProperty .

fract:action_lc3_2 a fract:AddPropertyDomainRange ;
    fract:sourceNode marnz:hasGuardian ;
    fract:targetNode mar:Guardian ;
    fract:axiomType rdfs:range ;
    fract:propertyType owl:ObjectProperty ;
    dash:shape shape:ShapeAddPropertyDomainRange .

fract:action_lc3_3 a fract:AddSuperclassAssertion ;
    fract:sourceNode mar:Whale ;
    fract:targetParent mar:NaturalLegalPerson ;
    dash:shape shape:ShapeAddSuperclassAssertion .

fract:action_lc3_4 a fract:AddPropertyRestriction ;
    fract:sourceNode mar:Whale ;
    fract:targetObject marnz:hasGuardian ;
    fract:targetObjectValue mar:Guardian ;
    fract:restrictionType owl:someValuesFrom ;
    fract:propertyType owl:ObjectProperty ;
    dash:shape shape:ShapeAddPropertyRestriction .

fract:action_lc3_5 a fract:ChangeAnnotationValue ;
    fract:sourceNode mar:Whale ;
    fract:targetAnnotation skos:definition ;
    fract:targetAnnotationValue "A large marine mammal of the order Cetacea, recognised as a legal person under New Zealand law." ;
    fract:targetLanguageTag "en" ;
    dash:shape shape:ShapeChangeAnnotationValue .
