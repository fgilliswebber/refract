@prefix fract: <https://w3id.org/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix sweet: <http://sweetontology.net/realmHydroBody/> .
@prefix sweetfr: <https://example.org/sweet/fr#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

fract:tmf_lc1 a fract:Manifest ;
    rdfs:label "Manifest 1.0.0 for localisation of SWEET Ontology Realm Hydrosphere Body to French Viewpoint"@en ;
    fract:transformationType fract:OntologyLocalisationProcess ;
    fract:transformationSource <http://sweetontology.net/realmHydroBody> ;
    fract:startingNode sweet:BodyOfWater ;
    fract:hasURIRelationshipToSource fract:DifferentRelationship ;
    fract:targetOntologyURI <https://example.org/sweet/fr> ;
    fract:targetViewpoint <https://semanticweb.tools/rdf/multi/language-french> ;
    fract:versionManifest fract:tmf_lc1_v1 ;
    dash:shape shape:ShapeLocalisation ;
    fract:hasAction fract:action_lc1_1, fract:action_lc1_2, fract:action_lc1_3,
                  fract:action_lc1_4, fract:action_lc1_5, fract:action_lc1_6 ;
    fract:actionOrder (
        fract:action_lc1_1
        fract:action_lc1_2
        fract:action_lc1_3
        fract:action_lc1_4
        fract:action_lc1_5
        fract:action_lc1_6
    ) .

fract:tmf_lc1_v1 a fract:Version ;
    fract:versionNumber "1.0.0" ;
    dct:date "2025-05-01" ;
    fract:versionPrevious fract:NoPreviousVersion ;
    dct:contributor "Frances Gillis-Webber" .
fract:action_lc1_1 a fract:DeleteClass ;
    fract:sourceNode sweet:River ;
    dash:shape shape:ShapeDeleteClass .

fract:action_lc1_2 a fract:AddClass ;
    fract:targetIdentifier sweetfr:Riviere ;
    fract:targetParent sweet:NaturalWaterBody ;
    fract:targetLabel "Rivière" ;
    fract:targetLanguageTag "fr" ;
    dash:shape shape:ShapeAddClass .

fract:action_lc1_3 a fract:AddClass ;
    fract:targetIdentifier sweetfr:Fleuve ;
    fract:targetParent sweet:NaturalWaterBody ;
    fract:targetLabel "Fleuve" ;
    fract:targetLanguageTag "fr" ;
    dash:shape shape:ShapeAddClass .

fract:action_lc1_4 a fract:AddSemanticAxiom ;
    fract:sourceNode sweetfr:Riviere ;
    fract:axiomType owl:disjointWith ;
    fract:targetNode sweetfr:Fleuve ;
    dash:shape shape:ShapeAddSemanticAxiom .

fract:action_lc1_5 a fract:AddAnnotationLangString ;
    fract:targetNode sweetfr:Riviere ;
    fract:targetAnnotation skos:definition ;
    fract:targetAnnotationValue "A river that flows into another river." ;
    fract:targetLanguageTag "fr" ;
    dash:shape shape:ShapeAddAnnotationLangString .

fract:action_lc1_6 a fract:AddAnnotationLangString ;
    fract:targetNode sweetfr:Fleuve ;
    fract:targetAnnotation skos:definition ;
    fract:targetAnnotationValue "A river that flows into the sea." ;
    fract:targetLanguageTag "fr" ;
    dash:shape shape:ShapeAddAnnotationLangString .
