@prefix uct: <https://example.org/uct#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<https://example.org/uct>
    a owl:Ontology ;
    rdfs:label "University of Cape Town (UCT) Organisational Structure"@en .

uct:AcademicUnit a owl:Class ;
    rdfs:label "Academic Unit"@en .

uct:Faculty a owl:Class ;
    rdfs:label "Faculty"@en ;
    rdfs:subClassOf uct:AcademicUnit .

uct:HumanitiesFaculty a owl:Class ;
    rdfs:label "Faculty of Humanities"@en ;
    rdfs:subClassOf uct:Faculty .

uct:SchoolOfLibraryStudies a owl:Class ;
    rdfs:label "School of Library Studies"@en ;
    rdfs:subClassOf uct:HumanitiesFaculty .