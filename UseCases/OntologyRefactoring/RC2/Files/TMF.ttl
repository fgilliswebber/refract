@prefix fract: <https://w3id.org/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix mola: <https://semanticweb.tools/ont/mola#> .

fract:tmf_rc2 a fract:Manifest ;
    rdfs:label "Manifest 1.0.0 for (partial) refactoring of MoLA ontology to OWL2_RL"@en ;
    fract:transformationType fract:OntologyRefactoringProcess ;
    fract:transformationSource <https://semanticweb.tools/ont/mola> ;
    fract:hasURIRelationshipToSource fract:SameVersionedRelationship ;
    fract:versionManifest fract:tmf_rc2_v1 ;
    dash:shape shape:ShapeRefactoring ;
    fract:hasAction fract:action_rc2_1 .

fract:tmf_rc2_v1 a fract:Version ;
    fract:versionNumber "1.0.0" ;
    dct:date "2025-05-01" ;
    fract:versionPrevious fract:NoPreviousVersion ;
    dct:contributor "Frances Gillis-Webber" .

fract:action_rc2_1 a fract:DeleteSuperclassAssertion ;
    fract:sourceNode mola:LanguageCode, mola:Period, mola:LanguoidName,
                   mola:GeographicCoordinate, mola:Languoid, mola:LanguageTag ;
    fract:targetParent owl:Thing ;
    dash:shape shape:ShapeDeleteSuperclassAssertion .
