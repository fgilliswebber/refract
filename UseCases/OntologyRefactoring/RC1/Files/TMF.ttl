@prefix fract: <https://w3id.org/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix edam: <http://edamontology.org/> .

fract:tmf_rc1 a fract:Manifest ;
    rdfs:label "Manifest 1.0.0 for refactoring of EDAM ontology"@en ;
    fract:transformationType fract:OntologyRefactoringProcess ;
    fract:transformationSource <http://edamontology.org/> ;
    fract:hasURIRelationshipToSource fract:SameVersionedRelationship ;
    fract:versionManifest fract:tmf_rc1_v1 ;
    dash:shape shape:ShapeRefactoring ;
    fract:hasAction fract:action_rc1_1 .

fract:tmf_rc1_v1 a fract:Version ;
    fract:versionNumber "1.0.0" ;
    dct:date "2025-05-01" ;
    fract:versionPrevious fract:NoPreviousVersion ;
    dct:contributor "Frances Gillis-Webber" .

fract:action_rc1_1 a fract:RenameClass ;
    fract:sourceNode edam:operation_2928 ;
    fract:targetIdentifier edam:operationAlignment ;
    fract:targetLabel "Alignment" ;
    fract:targetLanguageTag "en" ;
    dash:shape shape:ShapeRenameClass .
