@prefix fract: <https://w3id.org/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix multi: <https://w3id.org/MULTI#> .

fract:tmf_rc3 a fract:Manifest ;
    rdfs:label "Manifest 1.0.0 for refactoring of MULTI ontology"@en ;
    fract:transformationType fract:OntologyRefactoringProcess ;
    fract:transformationSource <https://w3id.org/MULTI> ;
    fract:hasURIRelationshipToSource fract:SameVersionedRelationship ;
    fract:versionManifest fract:tmf_rc3_v1 ;
    dash:shape shape:ShapeRefactoring ;
    fract:hasAction fract:action_rc3_1, fract:action_rc3_2 .

fract:tmf_rc3_v1 a fract:Version ;
    fract:versionNumber "1.0.0" ;
    dct:date "2025-05-01" ;
    fract:versionPrevious fract:NoPreviousVersion ;
    dct:contributor "Frances Gillis-Webber" .

fract:action_rc3_1 a fract:AddAnnotationLangString ;
    fract:sourceNode multi:Viewpoint ;
    fract:targetAnnotation rdfs:label ;
    fract:targetAnnotationValue "Standpunt" ;
    fract:targetLanguageTag "af" ;
    dash:shape shape:ShapeAddAnnotationLangString .

fract:action_rc3_2 a fract:AddAnnotationLangString ;
    fract:sourceNode multi:Viewpoint ;
    fract:targetAnnotation rdfs:label ;
    fract:targetAnnotationValue "Point de vue" ;
    fract:targetLanguageTag "fr" ;
    dash:shape shape:ShapeAddAnnotationLangString .
