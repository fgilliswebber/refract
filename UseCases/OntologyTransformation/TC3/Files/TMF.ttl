@prefix fract: <https://w3id.org/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix mola: <https://semanticweb.tools/ont/mola#> .

fract:tmf_tc3 a fract:Manifest ;
    rdfs:label "Manifest 1.0.0 for transformation of MoLA Ontology to OWL2_RL Context"@en ;
    fract:transformationType fract:OntologyTransformationProcess ;
    fract:transformationSource <https://semanticweb.tools/ont/mola> ;
    fract:hasURIRelationshipToSource fract:DifferentRelationship ;
    fract:targetOntologyURI <https://semanticweb.tools/ont/mola/rl> ;
    fract:targetViewpoint <https://semanticweb.tools/rdf/multi/owl2rl> ;
    fract:versionManifest fract:tmf_tc3_v1 ;
    dash:shape shape:ShapeTransformation ;
    fract:hasAction fract:action_tc3_1, fract:action_tc3_2, fract:action_tc3_3, fract:action_tc3_4 ;
    fract:actionOrder (
        fract:action_tc3_1
        fract:action_tc3_2
        fract:action_tc3_3
        fract:action_tc3_4
    ) .

fract:tmf_tc3_v1 a fract:Version ;
    fract:versionNumber "1.0.0" ;
    dct:date "2025-05-01" ;
    fract:versionPrevious fract:NoPreviousVersion ;
    dct:contributor "Frances Gillis-Webber" .

fract:action_tc3_1 a fract:DeleteCardinalityRestriction ;
    fract:sourceNode mola:Region ;
    fract:sourceProperty mola:hasCoordinate ;
    fract:sourceOnClass mola:GeographicCoordinate ;
    dash:shape shape:ShapeDeleteCardinalityRestriction .

fract:action_tc3_2 a fract:DeletePropertyDomainRange ;
    fract:sourceNode mola:hasMember ;
    fract:axiomType rdfs:domain ;
    dash:shape shape:ShapeDeletePropertyDomainRange .

fract:action_tc3_3 a fract:AddPropertyDomainRange ;
    fract:sourceNode mola:hasMember ;
    fract:targetNode mola:DialectCluster ;
    fract:axiomType rdfs:domain ;
    fract:propertyType owl:ObjectProperty ;
    dash:shape shape:ShapeAddPropertyDomainRange .

fract:action_tc3_4 a fract:AddPropertyDomainRange ;
    fract:sourceNode mola:hasMember ;
    fract:targetNode mola:LanguageFamily ;
    fract:axiomType rdfs:domain ;
    fract:propertyType owl:ObjectProperty ;
    dash:shape shape:ShapeAddPropertyDomainRange .
