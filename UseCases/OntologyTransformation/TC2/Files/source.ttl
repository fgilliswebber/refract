@prefix ch: <https://example.org/ch#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .

<https://example.org/ch>
    a owl:Ontology ;
    rdfs:label "Cultural Heritage Ontology"@en .

ch:CulturalObject a owl:Class ;
    rdfs:label "Cultural object"@en .

ch:HumanSpecimen a owl:Class ;
    rdfs:label "Human specimen"@en ;
    rdfs:subClassOf ch:CulturalObject .

ch:Acquisition a owl:Class ;
    rdfs:label "Acquisition"@en ;
    rdfs:subClassOf ch:CulturalObject .

ch:MuseumCollection a owl:Class ;
    rdfs:label "Museum collection"@en .

ch:MuseeDeLHomme a ch:MuseumCollection ;
    rdfs:label "Musée de l'Homme"@fr .

ch:VenusHottentote a ch:HumanSpecimen ;
    skos:prefLabel "Venus Hottentote"@fr ;
    rdfs:label "Saartjie Baartman"@af ;
    ch:acquiredBy ch:MuseeDeLHomme ;
    ch:acquisitionDate "1815"^^xsd:gYear ;
    ch:displayedUntil "1974"^^xsd:gYear .