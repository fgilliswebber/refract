@prefix fract: <https://w3id.org/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix recipe: <https://example.org/recipe#> .
@prefix recipeim: <https://example.org/recipe/imperial#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

fract:tmf_tc1 a fract:Manifest ;
    rdfs:label "Manifest 1.0.0 for transformation of Recipe Measurement Ontology to Imperial Viewpoint"@en ;
    fract:transformationType fract:OntologyTransformationProcess ;
    fract:transformationSource <https://example.org/recipe> ;
    fract:hasURIRelationshipToSource fract:DifferentRelationship ;
    fract:targetOntologyURI <https://example.org/recipe/imperial> ;
    fract:targetViewpoint <https://semanticweb.tools/rdf/multi/imperial> ;
    fract:versionManifest fract:tmf_tc1_v1 ;
    dash:shape shape:ShapeTransformation ;
    fract:hasAction fract:action_tc1_1, fract:action_tc1_2, fract:action_tc1_3, fract:action_tc1_4,
                  fract:action_tc1_5, fract:action_tc1_6, fract:action_tc1_7, fract:action_tc1_8,
                  fract:action_tc1_9, fract:action_tc1_10, fract:action_tc1_11, fract:action_tc1_12 ;
    fract:actionOrder (
        fract:action_tc1_1
        fract:action_tc1_2
        fract:action_tc1_3
        fract:action_tc1_4
        fract:action_tc1_5
        fract:action_tc1_6
        fract:action_tc1_7
        fract:action_tc1_8
        fract:action_tc1_9
        fract:action_tc1_10
        fract:action_tc1_11
        fract:action_tc1_12
    ) .

fract:tmf_tc1_v1 a fract:Version ;
    fract:versionNumber "1.0.0" ;
    dct:date "2025-05-01" ;
    fract:versionPrevious fract:NoPreviousVersion ;
    dct:contributor "Frances Gillis-Webber" .

fract:action_tc1_1 a fract:AddClass ;
    fract:targetIdentifier recipeim:ImperialUnit ;
    fract:targetParent recipe:Unit ;
    fract:targetLabel "Imperial unit" ;
    fract:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddClass .

fract:action_tc1_2 a fract:AddClass ;
    fract:targetIdentifier recipeim:Ounce ;
    fract:targetParent recipeim:ImperialUnit ;
    fract:targetLabel "Ounce" ;
    fract:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddClass .

fract:action_tc1_3 a fract:AddClass ;
    fract:targetIdentifier recipeim:FluidOunce ;
    fract:targetParent recipeim:ImperialUnit ;
    fract:targetLabel "Fluid ounce" ;
    fract:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddClass .

fract:action_tc1_4 a fract:AddClass ;
    fract:targetIdentifier recipeim:Fahrenheit ;
    fract:targetParent recipeim:ImperialUnit ;
    fract:targetLabel "Degree Fahrenheit" ;
    fract:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddClass .

fract:action_tc1_5 a fract:AddAnnotation ;
    fract:targetNode recipeim:Ounce ;
    fract:targetAnnotation qudt:conversionMultiplier ;
    fract:targetAnnotationValue "28.3495" ;
    fract:targetDataType xsd:decimal ;
    dash:shape shape:ShapeAddAnnotation .

fract:action_tc1_6 a fract:AddAnnotation ;
    fract:targetNode recipeim:FluidOunce ;
    fract:targetAnnotation qudt:conversionMultiplier ;
    fract:targetAnnotationValue "29.5735" ;
    fract:targetDataType xsd:decimal ;
    dash:shape shape:ShapeAddAnnotation .

fract:action_tc1_7 a fract:AddAnnotation ;
    fract:targetNode recipeim:Fahrenheit ;
    fract:targetAnnotation qudt:conversionMultiplier ;
    fract:targetAnnotationValue "1.8" ;
    fract:targetDataType xsd:decimal ;
    dash:shape shape:ShapeAddAnnotation .

fract:action_tc1_8 a fract:AddAnnotation ;
    fract:targetNode recipeim:Fahrenheit ;
    fract:targetAnnotation qudt:conversionOffset ;
    fract:targetAnnotationValue "32" ;
    fract:targetDataType xsd:decimal ;
    dash:shape shape:ShapeAddAnnotation .

fract:action_tc1_9 a fract:DeleteClass ;
    fract:sourceNode recipe:MetricUnit ;
    dash:shape shape:ShapeDeleteClass .

fract:action_tc1_10 a fract:DeleteClass ;
    fract:sourceNode recipe:Gram ;
    dash:shape shape:ShapeDeleteClass .

fract:action_tc1_11 a fract:DeleteClass ;
    fract:sourceNode recipe:Millilitre ;
    dash:shape shape:ShapeDeleteClass .

fract:action_tc1_12 a fract:DeleteClass ;
    fract:sourceNode recipe:Celsius ;
    dash:shape shape:ShapeDeleteClass .
