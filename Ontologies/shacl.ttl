  :datatype xsd:boolean;
  :path :uniqueLang;
  :maxCount 1;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#> .

:uniqueLang a owl:NamedIndividual;
  rdfs:comment "Specifies whether all node values must have a unique (or no) language tag."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "unique languages"@en .

:Violation a owl:NamedIndividual, :Severity;
  rdfs:comment "The severity for a violation validation result."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "Violation"@en .

:Warning a owl:NamedIndividual, :Severity;
  rdfs:comment "The severity for a warning validation result."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "Warning"@en .

:XoneConstraintComponent a owl:NamedIndividual, :ConstraintComponent;
  :parameter :XoneConstraintComponent-xone;
  rdfs:comment "A constraint component that can be used to restrict the value nodes so that they conform to exactly one out of several provided shapes."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "Exactly one constraint component"@en .

:XoneConstraintComponent-xone a owl:NamedIndividual, :Parameter;
  :path :xone;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#> .

:xone a owl:NamedIndividual;
  rdfs:comment "Specifies a list of shapes so that the value nodes must conform to exactly one of the shapes."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "exactly one"@en .

:expression rdfs:comment "The node expression that must return true for the value nodes."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "expression"@en .

:hasValue rdfs:comment "Specifies a value that must be among the value nodes."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "has value"@en .

:maxExclusive rdfs:comment "Specifies the maximum exclusive value of each value node."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "max exclusive"@en .

:maxInclusive rdfs:comment "Specifies the maximum inclusive value of each value node."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "max inclusive"@en .

:minExclusive rdfs:comment "Specifies the minimum exclusive value of each value node."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "min exclusive"@en .

:minInclusive rdfs:comment "Specifies the minimum inclusive value of each value node."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "min inclusive"@en .

:this a owl:NamedIndividual, rdfs:Resource;
  rdfs:comment "A node expression that represents the current focus node."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "this"@en .

:and rdfs:comment "RDF list of shapes to validate the value nodes against."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "and"@en .

:class rdfs:comment "The type that all value nodes must have."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "class"@en .

:closed rdfs:comment "If set to true then the shape is closed."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "closed"@en .

:datatype rdfs:comment "Specifies an RDF datatype that all value nodes must have."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "datatype"@en .

:disjoint rdfs:comment "Specifies a property where the set of values must be disjoint with the value nodes."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "disjoint"@en .

:equals rdfs:comment "Specifies a property that must have the same values as the value nodes."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "equals"@en .

:flags rdfs:comment "An optional flag to be used with regular expression pattern matching."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "flags"@en .

:ignoredProperties rdfs:comment "An optional RDF list of properties that are also permitted in addition to those explicitly enumerated via sh:property/sh:path."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "ignored properties"@en .

:in rdfs:comment "Specifies a list of allowed values so that each value node must be among the members of the given list."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "in"@en .

:intersection rdfs:comment "A list of node expressions that shall be intersected."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "intersection"@en .

:js rdfs:comment "Constraints expressed in JavaScript.";
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "JavaScript constraint"@en .

:languageIn rdfs:comment "Specifies a list of language tags that all value nodes must have."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "language in"@en .

:lessThan rdfs:comment "Specifies a property that must have smaller values than the value nodes."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "less than"@en .

:lessThanOrEquals rdfs:comment "Specifies a property that must have smaller or equal values than the value nodes."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "less than or equals"@en .

:maxCount rdfs:comment "Specifies the maximum number of values in the set of value nodes."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "max count"@en .

:maxLength rdfs:comment "Specifies the maximum string length of each value node."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "max length"@en .

:message rdfs:comment "A human-readable message (possibly with placeholders for variables) explaining the cause of the result."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "message"@en .

:minCount rdfs:comment "Specifies the minimum number of values in the set of value nodes."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "min count"@en .

:minLength rdfs:comment "Specifies the minimum string length of each value node."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "min length"@en .

:node rdfs:comment "Specifies the node shape that all value nodes must conform to."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "node"@en .

:nodeKind rdfs:comment "Specifies the node kind (e.g. IRI or literal) each value node."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "node kind"@en .

:nodes rdfs:comment "The node expression producing the input nodes of a filter shape expression."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "nodes"@en .

:not rdfs:comment "Specifies a shape that the value nodes must not conform to."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "not"@en .

:or rdfs:comment "Specifies a list of shapes so that the value nodes must conform to at least one of the shapes."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "or"@en .

:order rdfs:comment "Specifies the relative order of this compared to its siblings. For example use 0 for the first, 1 for the second."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "order"@en .

:pattern rdfs:comment "Specifies a regular expression pattern that the string representations of the value nodes must match."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "pattern"@en .

:union rdfs:comment "A list of node expressions that shall be used together."@en;
  rdfs:isDefinedBy <http://www.w3.org/ns/shacl#>;
  rdfs:label "union"@en .
