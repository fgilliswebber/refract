dash:template rdf:type owl:NamedIndividual .


###  http://datashapes.org/dash#toString
dash:toString rdf:type owl:NamedIndividual ,
                       sh:SPARQLFunction ;
              sh:parameter _:genid28 ;
              sh:prefixes <http://datashapes.org/dash> ;
              sh:returnType xsd:string ;
              dash:cachable "true"^^xsd:boolean ;
              sh:select """SELECT (xsd:string($arg) AS ?result)
WHERE {
}""" ;
              rdfs:comment "Returns a literal with datatype xsd:string that has the input value as its string. If the input value is an (URI) resource then its URI will be used." ;
              rdfs:label "to string" ;
              sh:labelTemplate "Convert {$arg} to xsd:string" .

_:genid28 rdf:type sh:Parameter ;
           sh:nodeKind sh:IRIOrLiteral ;
           sh:path dash:arg ;
           sh:description "The input value." ;
           sh:name "arg" .


###  http://datashapes.org/dash#uniqueValueForClass
dash:uniqueValueForClass rdf:type owl:NamedIndividual ;
                         rdfs:label "unique value for class" .


###  http://datashapes.org/dash#uriStart
dash:uriStart rdf:type owl:NamedIndividual .


###  http://datashapes.org/dash#uriTemplate
dash:uriTemplate rdf:type owl:NamedIndividual ,
                          sh:SPARQLFunction ;
                 dash:apiStatus dash:Stable ;
                 sh:parameter _:genid29 ,
                              _:genid30 ;
                 sh:prefixes <http://datashapes.org/dash> ;
                 sh:returnType xsd:anyURI ;
                 dash:cachable "true"^^xsd:boolean ;
                 dash:contextFree "true"^^xsd:boolean ;
                 sh:select """SELECT ?result
WHERE {
    	BIND (xsd:anyURI(REPLACE(?template, \"\\\\{[a-zA-Z]+\\\\}\", $value)) AS ?result)
}""" ;
                 rdfs:comment """Inserts a given value into a given URI template, producing a new xsd:anyURI literal.

In the future this should support RFC 6570 but for now it is limited to simple {...} patterns.""" ;
                 rdfs:label "URI template" .

_:genid29 rdf:type sh:Parameter ;
           sh:datatype xsd:string ;
           sh:path dash:template ;
           sh:order 0 ;
           sh:description "The URI template, e.g. \"http://example.org/{symbol}\"." ;
           sh:name "template" .

_:genid30 rdf:type sh:Parameter ;
           sh:nodeKind sh:Literal ;
           sh:path dash:value ;
           sh:order 1 ;
           sh:description "The literal value to insert into the template. Will use the URI-encoded string of the lexical form (for now)." ;
           sh:name "value" .


###  http://datashapes.org/dash#value
dash:value rdf:type owl:NamedIndividual .


###  http://datashapes.org/dash#valueCount
dash:valueCount rdf:type owl:NamedIndividual ,
                         sh:SPARQLFunction ;
                dash:apiStatus dash:Stable ;
                sh:parameter _:genid31 ,
                             _:genid32 ;
                sh:prefixes <http://datashapes.org/dash> ;
                sh:returnType xsd:integer ;
                sh:select """
		SELECT (COUNT(?object) AS ?result)
		WHERE {
    		$subject $predicate ?object .
		}
""" ;
                rdfs:comment "Computes the number of objects for a given subject/predicate combination." ;
                rdfs:label "value count" .

_:genid31 rdf:type sh:Parameter ;
           sh:class rdfs:Resource ;
           sh:path dash:subject ;
           sh:order 0 ;
           sh:description "The subject to get the number of objects of." ;
           sh:name "subject" .

_:genid32 rdf:type sh:Parameter ;
           sh:class rdfs:Resource ;
           sh:path dash:predicate ;
           sh:order 1 ;
           sh:description "The predicate to get the number of objects of." ;
           sh:name "predicate" .


