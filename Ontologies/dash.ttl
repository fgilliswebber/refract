dash:TestCase rdf:type owl:Class ;
              rdfs:subClassOf rdfs:Resource .


###  http://datashapes.org/dash#TestCaseResult
dash:TestCaseResult rdf:type owl:Class ;
                    rdfs:subClassOf sh:AbstractResult .


###  http://datashapes.org/dash#TestEnvironment
dash:TestEnvironment rdf:type owl:Class ;
                     rdfs:subClassOf rdfs:Resource .


###  http://datashapes.org/dash#ValidationTestCase
dash:ValidationTestCase rdf:type owl:Class ;
                        rdfs:subClassOf dash:TestCase .


