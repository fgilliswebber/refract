dash:StringOrLangString rdf:type owl:NamedIndividual ;
                        rdfs:comment "An rdf:List that can be used in property constraints as value for sh:or to indicate that all values of a property must be either xsd:string or rdf:langString." ;
                        rdfs:label "String or langString" .


###  http://datashapes.org/dash#SubClassEditor
dash:SubClassEditor rdf:type owl:NamedIndividual ,
                             dash:SingleEditor ;
                    rdfs:comment "An editor for properties that declare a dash:rootClass. The editor allows selecting either the class itself or one of its subclasses." ;
                    rdfs:label "Sub-Class editor" .


###  http://datashapes.org/dash#SubSetOfConstraintComponent
dash:SubSetOfConstraintComponent rdf:type owl:NamedIndividual ,
                                          sh:ConstraintComponent ;
                                 sh:parameter dash:SubSetOfConstraintComponent-subSetOf ;
                                 sh:propertyValidator _:genid21 ;
                                 dash:localConstraint "true"^^xsd:boolean ;
                                 rdfs:comment "A constraint component that can be used to state that the set of value nodes must be a subset of the value of a given property." ;
                                 rdfs:label "Sub set of constraint component" ;
                                 sh:message "Must be one of the values of {$subSetOf}" .

_:genid21 rdf:type sh:SPARQLAskValidator ;
           sh:prefixes <http://datashapes.org/dash> ;
           sh:ask """ASK {
    $this $subSetOf $value .
}""" .


###  http://datashapes.org/dash#SubSetOfConstraintComponent-subSetOf
dash:SubSetOfConstraintComponent-subSetOf rdf:type owl:NamedIndividual ,
                                                   sh:Parameter ;
                                          dash:editor dash:PropertyAutoCompleteEditor ;
                                          dash:reifiableBy dash:ConstraintReificationShape ;
                                          dash:viewer dash:PropertyLabelViewer ;
                                          sh:nodeKind sh:IRI ;
                                          sh:path dash:subSetOf ;
                                          sh:description "Can be used to state that all value nodes must also be values of a specified other property at the same focus node." ;
                                          sh:name "sub-set of" .


###  http://datashapes.org/dash#Suggestion
dash:Suggestion rdf:type owl:NamedIndividual ;
                dash:abstract "true"^^xsd:boolean .


###  http://datashapes.org/dash#SuggestionGenerator
dash:SuggestionGenerator rdf:type owl:NamedIndividual ;
                         dash:abstract "true"^^xsd:boolean .


###  http://datashapes.org/dash#SymmetricConstraintComponent
dash:SymmetricConstraintComponent rdf:type owl:NamedIndividual ,
                                           sh:ConstraintComponent ;
                                  sh:parameter dash:SymmetricConstraintComponent-symmetric ;
                                  sh:propertyValidator _:genid22 ;
                                  rdfs:comment "A contraint component for property shapes to validate that a property is symmetric. For symmetric properties, if A relates to B then B must relate to A." ;
                                  rdfs:label "Symmetric constraint component" ;
                                  sh:message "Symmetric value expected" .

_:genid22 rdf:type sh:SPARQLSelectValidator ;
           sh:prefixes <http://datashapes.org/dash> ;
           sh:select """SELECT $this ?value {
	FILTER ($symmetric) .
	$this $PATH ?value .
	FILTER NOT EXISTS {
    	?value $PATH $this .
	}
}""" .


###  http://datashapes.org/dash#SymmetricConstraintComponent-symmetric
dash:SymmetricConstraintComponent-symmetric rdf:type owl:NamedIndividual ,
                                                     sh:Parameter ;
                                            dash:reifiableBy dash:ConstraintReificationShape ;
                                            sh:datatype xsd:boolean ;
                                            sh:path dash:symmetric ;
                                            sh:maxCount 1 ;
                                            sh:description "If set to true then if A relates to B then B must relate to A." ;
                                            sh:name "symmetric" .


###  http://datashapes.org/dash#TestCase
dash:TestCase rdf:type owl:NamedIndividual ,
                       dash:ShapeClass ;
              dash:abstract "true"^^xsd:boolean .


###  http://datashapes.org/dash#TestCaseResult
dash:TestCaseResult rdf:type owl:NamedIndividual ;
                    dash:abstract "true"^^xsd:boolean .


###  http://datashapes.org/dash#TestEnvironment
dash:TestEnvironment rdf:type owl:NamedIndividual ;
                     dash:abstract "true"^^xsd:boolean .


###  http://datashapes.org/dash#TextAreaEditor
dash:TextAreaEditor rdf:type owl:NamedIndividual ,
                             dash:SingleEditor ;
                    rdfs:comment "A multi-line text area to enter the value of a literal." ;
                    rdfs:label "Text area editor" .


###  http://datashapes.org/dash#TextAreaWithLangEditor
dash:TextAreaWithLangEditor rdf:type owl:NamedIndividual ,
                                     dash:SingleEditor ;
                            rdfs:comment "A multi-line text area to enter the value of a literal and a drop down to select a language." ;
                            rdfs:label "Text area with lang editor" .


###  http://datashapes.org/dash#TextFieldEditor
dash:TextFieldEditor rdf:type owl:NamedIndividual ,
                              dash:SingleEditor ;
                     rdfs:comment """A simple input field to enter the value of a literal, without the ability to change language or datatype.

This is the fallback editor for any literal if no other editors are more suitable.""" ;
                     rdfs:label "Text field editor" .


###  http://datashapes.org/dash#TextFieldWithLangEditor
dash:TextFieldWithLangEditor rdf:type owl:NamedIndividual ,
                                      dash:SingleEditor ;
                             rdfs:comment "A single-line input field to enter the value of a literal and a drop down to select language, which is mandatory unless xsd:string is among the permissible datatypes." ;
                             rdfs:label "Text field with lang editor" .


###  http://datashapes.org/dash#URIEditor
dash:URIEditor rdf:type owl:NamedIndividual ,
                        dash:SingleEditor ;
               rdfs:comment "An input field to enter the URI of a resource, e.g. rdfs:seeAlso links or images." ;
               rdfs:label "URI editor" .


###  http://datashapes.org/dash#URIViewer
dash:URIViewer rdf:type owl:NamedIndividual ,
                        dash:SingleViewer ;
               rdfs:comment "A Viewer for URI resources, rendering as a hyperlink to that URI. Also includes other ways of interacting with the URI such as opening a nested summary display." ;
               rdfs:label "URI viewer" .


###  http://datashapes.org/dash#UniqueValueForClassConstraintComponent
dash:UniqueValueForClassConstraintComponent rdf:type owl:NamedIndividual ,
                                                     sh:ConstraintComponent ;
                                            sh:parameter dash:UniqueValueForClassConstraintComponent-uniqueValueForClass ;
                                            sh:propertyValidator _:genid23 ;
                                            rdfs:comment "A constraint component that can be used to state that the values of a property must be unique for all instances of a given class (and its subclasses)." ;
                                            rdfs:label "Unique value for class constraint component" ;
                                            sh:labelTemplate "Values must be unique among all instances of {?uniqueValueForClass}" .

_:genid23 rdf:type sh:SPARQLSelectValidator ;
           sh:prefixes <http://datashapes.org/dash> ;
           sh:select """SELECT DISTINCT $this ?value ?other
WHERE {
	{
    	$this $PATH ?value .
		?other $PATH ?value .
		FILTER (?other != $this) .
	}
	?other a ?type .
	?type rdfs:subClassOf* $uniqueValueForClass .
}""" ;
           sh:message "Value {?value} must be unique but is also used by {?other}" .


###  http://datashapes.org/dash#UniqueValueForClassConstraintComponent-uniqueValueForClass
dash:UniqueValueForClassConstraintComponent-uniqueValueForClass rdf:type owl:NamedIndividual ,
                                                                         sh:Parameter ;
                                                                dash:reifiableBy dash:ConstraintReificationShape ;
                                                                sh:class rdfs:Class ;
                                                                sh:nodeKind sh:IRI ;
                                                                sh:path dash:uniqueValueForClass ;
                                                                sh:description "States that the values of the property must be unique for all instances of a given class (and its subclasses)." ;
                                                                sh:name "unique value for class" .


###  http://datashapes.org/dash#UntrustedHTMLViewer
dash:UntrustedHTMLViewer rdf:type owl:NamedIndividual ,
                                  dash:SingleViewer ;
                         rdfs:comment "A Viewer for HTML content from untrusted sources. This viewer will sanitize the HTML before rendering. Any a, button, checkbox, form, hidden, input, img, script, select, style and textarea tags and class and style attributes will be removed." ;
                         rdfs:label "Untrusted HTML viewer" .


###  http://datashapes.org/dash#ValidationTestCase
dash:ValidationTestCase rdf:type owl:NamedIndividual ,
                                 dash:ShapeClass ;
                        dash:abstract "true"^^xsd:boolean .


###  http://datashapes.org/dash#ValueTableViewer
dash:ValueTableViewer rdf:type owl:NamedIndividual ,
                               dash:MultiViewer ;
                      rdfs:comment "A viewer that renders all values of a given property as a table, with one value per row, and the columns defined by the shape that is the sh:node or sh:class of the property." ;
                      rdfs:label "Value table viewer" .


###  http://datashapes.org/dash#Viewer
dash:Viewer rdf:type owl:NamedIndividual ,
                     dash:ShapeClass ;
            dash:abstract "true"^^xsd:boolean .


###  http://datashapes.org/dash#Widget
dash:Widget rdf:type owl:NamedIndividual ,
                     dash:ShapeClass ;
            dash:abstract "true"^^xsd:boolean .


###  http://datashapes.org/dash#all
dash:all rdf:type owl:NamedIndividual ,
                  rdfs:Resource ;
         rdfs:comment "Represents all users/roles, for example as a possible value of the default view for role property." ;
         rdfs:label "all" .


###  http://datashapes.org/dash#arg
dash:arg rdf:type owl:NamedIndividual .


###  http://datashapes.org/dash#closedByTypes
dash:closedByTypes rdf:type owl:NamedIndividual ;
                   rdfs:label "closed by types" .


###  http://datashapes.org/dash#coExistsWith
dash:coExistsWith rdf:type owl:NamedIndividual .


###  http://datashapes.org/dash#constraintOrShape
dash:constraintOrShape rdf:type owl:NamedIndividual .


###  http://datashapes.org/dash#generateClass
dash:generateClass rdf:type owl:NamedIndividual .


###  http://datashapes.org/dash#generatePrefixClasses
dash:generatePrefixClasses rdf:type owl:NamedIndividual .


###  http://datashapes.org/dash#generatePrefixConstants
dash:generatePrefixConstants rdf:type owl:NamedIndividual .


###  http://datashapes.org/dash#hasClass
dash:hasClass rdf:type owl:NamedIndividual ,
                       sh:SPARQLAskValidator ;
              sh:prefixes <http://datashapes.org/dash> ;
              sh:ask """
		ASK {
			$value rdf:type/rdfs:subClassOf* $class .
		}
		""" ;
              rdfs:label "has class" ;
              sh:message "Value does not have class {$class}" .


###  http://datashapes.org/dash#hasMaxExclusive
dash:hasMaxExclusive rdf:type owl:NamedIndividual ,
                              sh:SPARQLAskValidator ;
                     sh:prefixes <http://datashapes.org/dash> ;
                     sh:ask "ASK { FILTER ($value < $maxExclusive) }" ;
                     rdfs:comment "Checks whether a given node (?value) has a value less than (<) the provided ?maxExclusive. Returns false if this cannot be determined, e.g. because values do not have comparable types." ;
                     rdfs:label "has max exclusive" .


###  http://datashapes.org/dash#hasMaxInclusive
dash:hasMaxInclusive rdf:type owl:NamedIndividual ,
                              sh:SPARQLAskValidator ;
                     sh:prefixes <http://datashapes.org/dash> ;
                     sh:ask "ASK { FILTER ($value <= $maxInclusive) }" ;
                     rdfs:comment "Checks whether a given node (?value) has a value less than or equal to (<=) the provided ?maxInclusive. Returns false if this cannot be determined, e.g. because values do not have comparable types." ;
                     rdfs:label "has max inclusive" .


###  http://datashapes.org/dash#hasMaxLength
dash:hasMaxLength rdf:type owl:NamedIndividual ,
                           sh:SPARQLAskValidator ;
                  sh:prefixes <http://datashapes.org/dash> ;
                  sh:ask """
		ASK {
			FILTER (STRLEN(str($value)) <= $maxLength) .
		}
		""" ;
                  rdfs:comment "Checks whether a given string (?value) has a length within a given maximum string length." ;
                  rdfs:label "has max length" .


###  http://datashapes.org/dash#hasMinExclusive
dash:hasMinExclusive rdf:type owl:NamedIndividual ,
                              sh:SPARQLAskValidator ;
                     sh:prefixes <http://datashapes.org/dash> ;
                     sh:ask "ASK { FILTER ($value > $minExclusive) }" ;
                     rdfs:comment "Checks whether a given node (?value) has value greater than (>) the provided ?minExclusive. Returns false if this cannot be determined, e.g. because values do not have comparable types." ;
                     rdfs:label "has min exclusive" .


###  http://datashapes.org/dash#hasMinInclusive
dash:hasMinInclusive rdf:type owl:NamedIndividual ,
                              sh:SPARQLAskValidator ;
                     sh:prefixes <http://datashapes.org/dash> ;
                     sh:ask "ASK { FILTER ($value >= $minInclusive) }" ;
                     rdfs:comment "Checks whether a given node (?value) has value greater than or equal to (>=) the provided ?minInclusive. Returns false if this cannot be determined, e.g. because values do not have comparable types." ;
                     rdfs:label "has min inclusive" .


###  http://datashapes.org/dash#hasMinLength
dash:hasMinLength rdf:type owl:NamedIndividual ,
                           sh:SPARQLAskValidator ;
                  sh:prefixes <http://datashapes.org/dash> ;
                  sh:ask """
		ASK {
			FILTER (STRLEN(str($value)) >= $minLength) .
		}
		""" ;
                  rdfs:comment "Checks whether a given string (?value) has a length within a given minimum string length." ;
                  rdfs:label "has min length" .


###  http://datashapes.org/dash#hasNodeKind
dash:hasNodeKind rdf:type owl:NamedIndividual ,
                          sh:SPARQLAskValidator ;
                 sh:prefixes <http://datashapes.org/dash> ;
                 sh:ask """
		ASK {
			FILTER ((isIRI($value) && $nodeKind IN ( sh:IRI, sh:BlankNodeOrIRI, sh:IRIOrLiteral ) ) ||
				(isLiteral($value) && $nodeKind IN ( sh:Literal, sh:BlankNodeOrLiteral, sh:IRIOrLiteral ) ) ||
				(isBlank($value)   && $nodeKind IN ( sh:BlankNode, sh:BlankNodeOrIRI, sh:BlankNodeOrLiteral ) )) .
		}
		""" ;
                 rdfs:comment "Checks whether a given node (?value) has a given sh:NodeKind (?nodeKind). For example, sh:hasNodeKind(42, sh:Literal) = true." ;
                 rdfs:label "has node kind" .


###  http://datashapes.org/dash#hasPattern
dash:hasPattern rdf:type owl:NamedIndividual ,
                         sh:SPARQLAskValidator ;
                sh:prefixes <http://datashapes.org/dash> ;
                sh:ask "ASK { FILTER (!isBlank($value) && IF(bound($flags), regex(str($value), $pattern, $flags), regex(str($value), $pattern))) }" ;
                rdfs:comment "Checks whether the string representation of a given node (?value) matches a given regular expression (?pattern). Returns false if the value is a blank node." ;
                rdfs:label "has pattern" .


###  http://datashapes.org/dash#hasRootClass
dash:hasRootClass rdf:type owl:NamedIndividual ,
                           sh:SPARQLAskValidator ;
                  sh:prefixes <http://datashapes.org/dash> ;
                  sh:ask """ASK {
    $value rdfs:subClassOf* $rootClass .
}""" ;
                  rdfs:label "has root class" .


###  http://datashapes.org/dash#hasStem
dash:hasStem rdf:type owl:NamedIndividual ,
                      sh:SPARQLAskValidator ;
             sh:prefixes <http://datashapes.org/dash> ;
             sh:ask "ASK { FILTER (isIRI($value) && STRSTARTS(str($value), $stem)) }" ;
             rdfs:comment "Checks whether a given node is an IRI starting with a given stem." ;
             rdfs:label "has stem" .


###  http://datashapes.org/dash#hasValueIn
dash:hasValueIn rdf:type owl:NamedIndividual .


###  http://datashapes.org/dash#hasValueWithClass
dash:hasValueWithClass rdf:type owl:NamedIndividual .


###  http://datashapes.org/dash#indexed
dash:indexed rdf:type owl:NamedIndividual .


###  http://datashapes.org/dash#isDeactivated
dash:isDeactivated rdf:type owl:NamedIndividual ,
                            sh:SPARQLFunction ;
                   dash:apiStatus dash:Stable ;
                   sh:parameter _:genid24 ;
                   sh:prefixes <http://datashapes.org/dash> ;
                   sh:returnType xsd:boolean ;
                   sh:ask """ASK {
    ?constraintOrShape sh:deactivated true .
}""" ;
                   rdfs:comment "Checks whether a given shape or constraint has been marked as \"deactivated\" using sh:deactivated." ;
                   rdfs:label "is deactivated" .

_:genid24 rdf:type sh:Parameter ;
           sh:path dash:constraintOrShape ;
           sh:description "The sh:Constraint or sh:Shape to test." ;
           sh:name "constraint or shape" .


###  http://datashapes.org/dash#isIn
dash:isIn rdf:type owl:NamedIndividual ,
                   sh:SPARQLAskValidator ;
          sh:prefixes <http://datashapes.org/dash> ;
          sh:ask """
		ASK {
			GRAPH $shapesGraph {
				$in (rdf:rest*)/rdf:first $value .
			}
		}
		""" ;
          rdfs:label "is in" .


###  http://datashapes.org/dash#isLanguageIn
dash:isLanguageIn rdf:type owl:NamedIndividual ,
                           sh:SPARQLAskValidator ;
                  sh:prefixes <http://datashapes.org/dash> ;
                  sh:ask """
		ASK {
			BIND (lang($value) AS ?valueLang) .
			FILTER EXISTS {
				GRAPH $shapesGraph {
					$languageIn (rdf:rest*)/rdf:first ?lang .
				    FILTER (langMatches(?valueLang, ?lang))
				} }
		}
		""" ;
                  rdfs:label "is language in" .


###  http://datashapes.org/dash#isNodeKindBlankNode
dash:isNodeKindBlankNode rdf:type owl:NamedIndividual ,
                                  sh:SPARQLFunction ;
                         dash:apiStatus dash:Stable ;
                         sh:parameter _:genid25 ;
                         sh:prefixes <http://datashapes.org/dash> ;
                         sh:returnType xsd:boolean ;
                         dash:cachable "true"^^xsd:boolean ;
                         dash:contextFree "true"^^xsd:boolean ;
                         sh:ask """ASK {
	FILTER ($nodeKind IN ( sh:BlankNode, sh:BlankNodeOrIRI, sh:BlankNodeOrLiteral ))
}""" ;
                         rdfs:comment "Checks if a given sh:NodeKind is one that includes BlankNodes." ;
                         rdfs:label "is NodeKind BlankNode" .

_:genid25 rdf:type sh:Parameter ;
           sh:class sh:NodeKind ;
           sh:nodeKind sh:IRI ;
           sh:path dash:nodeKind ;
           sh:description "The sh:NodeKind to check." ;
           sh:name "node kind" .


###  http://datashapes.org/dash#isNodeKindIRI
dash:isNodeKindIRI rdf:type owl:NamedIndividual ,
                            sh:SPARQLFunction ;
                   dash:apiStatus dash:Stable ;
                   sh:parameter _:genid26 ;
                   sh:prefixes <http://datashapes.org/dash> ;
                   sh:returnType xsd:boolean ;
                   dash:cachable "true"^^xsd:boolean ;
                   dash:contextFree "true"^^xsd:boolean ;
                   sh:ask """ASK {
	FILTER ($nodeKind IN ( sh:IRI, sh:BlankNodeOrIRI, sh:IRIOrLiteral ))
}""" ;
                   rdfs:comment "Checks if a given sh:NodeKind is one that includes IRIs." ;
                   rdfs:label "is NodeKind IRI" .

_:genid26 rdf:type sh:Parameter ;
           sh:class sh:NodeKind ;
           sh:nodeKind sh:IRI ;
           sh:path dash:nodeKind ;
           sh:description "The sh:NodeKind to check." ;
           sh:name "node kind" .


###  http://datashapes.org/dash#isNodeKindLiteral
dash:isNodeKindLiteral rdf:type owl:NamedIndividual ,
                                sh:SPARQLFunction ;
                       dash:apiStatus dash:Stable ;
                       sh:parameter _:genid27 ;
                       sh:prefixes <http://datashapes.org/dash> ;
                       sh:returnType xsd:boolean ;
                       dash:cachable "true"^^xsd:boolean ;
                       dash:contextFree "true"^^xsd:boolean ;
                       sh:ask """ASK {
	FILTER ($nodeKind IN ( sh:Literal, sh:BlankNodeOrLiteral, sh:IRIOrLiteral ))
}""" ;
                       rdfs:comment "Checks if a given sh:NodeKind is one that includes Literals." ;
                       rdfs:label "is NodeKind Literal" .

_:genid27 rdf:type sh:Parameter ;
           sh:class sh:NodeKind ;
           sh:nodeKind sh:IRI ;
           sh:path dash:nodeKind ;
           sh:description "The sh:NodeKind to check." ;
           sh:name "node kind" .


###  http://datashapes.org/dash#isSubClassOf
dash:isSubClassOf rdf:type owl:NamedIndividual ,
                           sh:SPARQLFunction ;
                  dash:apiStatus dash:Stable ;
                  sh:parameter dash:isSubClassOf-subclass ,
                               dash:isSubClassOf-superclass ;
                  sh:prefixes <http://datashapes.org/dash> ;
                  sh:returnType xsd:boolean ;
                  sh:ask """ASK {
    $subclass rdfs:subClassOf* $superclass .
}""" ;
                  rdfs:comment "Returns true if a given class (first argument) is a subclass of a given other class (second argument), or identical to that class. This is equivalent to an rdfs:subClassOf* check." ;
                  rdfs:label "is subclass of" .


###  http://datashapes.org/dash#isSubClassOf-subclass
dash:isSubClassOf-subclass rdf:type owl:NamedIndividual ,
                                    sh:Parameter ;
                           sh:class rdfs:Class ;
                           sh:path dash:subclass ;
                           sh:description "The (potential) subclass." ;
                           sh:name "subclass" .


###  http://datashapes.org/dash#isSubClassOf-superclass
dash:isSubClassOf-superclass rdf:type owl:NamedIndividual ,
                                      sh:Parameter ;
                             sh:class rdfs:Class ;
                             sh:path dash:superclass ;
                             sh:order 1 ;
                             sh:description "The (potential) superclass." ;
                             sh:name "superclass" .


