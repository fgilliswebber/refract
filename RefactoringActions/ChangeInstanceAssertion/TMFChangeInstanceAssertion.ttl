@prefix fract: <https://w3id.org/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix sweetfr: <https://example.org/sweet/fr#> .
@prefix ex: <https://example.org/sweet/fr/instances#> .

fract:tmf_ChangeInstanceAssertion a fract:Manifest ;
    fract:transformationType fract:OntologyLocalisationProcess ;
    fract:transformationSource <https://example.org/sweet/fr> ;
    fract:hasURIRelationshipToSource fract:SameVersionedRelationship ;
    fract:hasAction fract:action_ChangeInstanceAssertion_1 .

fract:action_ChangeInstanceAssertion_1 a fract:ChangeInstanceAssertion ;
    fract:sourceNode ex:Seine ;
    fract:targetNode sweetfr:Fleuve ;
    dash:shape shape:ShapeChangeInstanceAssertion .
