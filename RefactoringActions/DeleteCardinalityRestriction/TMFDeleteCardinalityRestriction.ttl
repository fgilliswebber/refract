@prefix ref: <https://semanticweb.tools/ont/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix mola: <https://ontology.londisizwe.org/mola#> .

ref:tmf_DeleteCardinalityRestriction a ref:Manifest ;
    ref:transformationType ref:OntologyTransformationProcess ;
    ref:transformationSource <https://semanticweb.tools/ont/mola> ;
    ref:hasURIRelationshipToSource ref:SameVersioned ;
    ref:hasAction ref:action_DeleteCardinalityRestriction_1 .

ref:action_DeleteCardinalityRestriction_1 a ref:DeleteCardinalityRestriction ;
    ref:sourceNode mola:Region ;
    ref:sourceProperty mola:hasCoordinate ;
    ref:sourceOnClass mola:GeographicCoordinate ;
    dash:shape shape:ShapeDeleteCardinalityRestriction .
