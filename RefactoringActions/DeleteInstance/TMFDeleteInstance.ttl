@prefix fract: <https://w3id.org/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix ex: <https://example.org/vo/> .

fract:tmf_DeleteInstance a fract:Manifest ;
    fract:transformationType fract:OntologyEvolutionProcess ;
    fract:transformationSource <http://purl.obolibrary.org/obo/vo.owl> ;
    fract:hasURIRelationshipToSource fract:SameVersionedRelationship ;
    fract:hasAction fract:action_DeleteInstance_1 .

fract:action_DeleteInstance_1 a fract:DeleteInstance ;
    fract:sourceNode ex:PfizerBioNTech ;
    fract:checkForAssertion fract:IfTrueStop ;
    dash:shape shape:ShapeDeleteInstance .
