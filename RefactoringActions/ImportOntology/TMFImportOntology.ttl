@prefix fract: <https://w3id.org/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

fract:tmf_ImportOntology a fract:Manifest ;
    fract:transformationType fract:OntologyRefactoringProcess ;
    fract:transformationSource <http://example.org/ontology> ;
    fract:hasURIRelationshipToSource fract:SameVersionedRelationship ;
    fract:hasAction fract:action_ImportOntology_1 .

fract:action_ImportOntology_1 a fract:ImportOntology ;
    fract:sourceNode <http://example.org/ontology> ;
    fract:URI "http://www.w3.org/2004/02/skos/core"^^xsd:anyURI ;
    dash:shape shape:ShapeImportOntology .
