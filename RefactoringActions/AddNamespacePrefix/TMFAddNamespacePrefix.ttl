@prefix fract: <https://w3id.org/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

fract:tmf_AddNamespacePrefix a fract:Manifest ;
    fract:transformationType fract:OntologyRefactoringProcess ;
    fract:transformationSource <http://example.org/ontology> ;
    fract:hasURIRelationshipToSource fract:SameVersioned ;
    fract:hasAction fract:action_AddNamespacePrefix_1 .

fract:action_AddNamespacePrefix_1 a fract:AddNamespacePrefix ;
    sh:prefix "skos" ;
    sh:namespace "http://www.w3.org/2004/02/skos/core#"^^xsd:anyURI ;
    dash:shape shape:ShapeAddNamespacePrefix .
