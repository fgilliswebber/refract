@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix fract: <https://w3id.org/refract#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

shape:ShapeAddNamespacePrefix
    a sh:NodeShape ;
    rdfs:label "Shape Add Namespace Prefix" ;
    rdfs:comment "A shapes graph for validating an 'Add namespace prefix' refactoring action in a Transformation Manifest File." ;
    sh:targetClass fract:AddNamespacePrefix ;
    sh:property [
        sh:path sh:prefix ;
        sh:name "prefix" ;
        sh:description "The namespace prefix to be added to the ontology, expressed as a plain string." ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sh:namespace ;
        sh:name "namespace" ;
        sh:description "The namespace URI associated with the prefix, expressed as an xsd:anyURI." ;
        sh:datatype xsd:anyURI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] .
