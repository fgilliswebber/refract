@prefix ref: <http://semanticweb.tools/ont/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <http://example.org/ontology#> .

ref:tmf_ChangeAnnotationValue a ref:Manifest ;
    ref:transformationType ref:OntologyRefactoringProcess ;
    ref:transformationSource <http://example.org/ontology> ;
    ref:hasURIRelationshipToSource ref:SameVersioned ;
    ref:hasAction ref:action_ChangeAnnotationValue_1 .

ref:action_ChangeAnnotationValue_1 a ref:ChangeAnnotationValue ;
    ref:sourceNode ex:River ;
    ref:targetAnnotation rdfs:comment ;
    ref:targetLanguageTag "en" ;
    ref:targetAnnotationValue "A natural waterbody that flows into the sea." ;
    ref:checkForAnnotation ref:IfFalseStop ;
    ref:checkForAnnotation ref:IfMultipleStop ;
    dash:shape shape:ShapeChangeAnnotationValue .