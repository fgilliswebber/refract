@prefix fract: <https://w3id.org/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ex: <http://example.org/ontology#> .

fract:tmf_AddSemanticAxiomUnary a fract:Manifest ;
    fract:transformationType fract:OntologyRefactoringProcess ;
    fract:transformationSource <http://example.org/ontology> ;
    fract:hasURIRelationshipToSource fract:SameVersionedRelationship ;
    fract:hasAction fract:action_AddSemanticAxiomUnary_1 .

fract:action_AddSemanticAxiomUnary_1 a fract:AddSemanticAxiomUnary ;
    fract:sourceNode ex:hasGuardian ;
    fract:axiomType owl:TransitiveProperty ;
    dash:shape shape:ShapeAddSemanticAxiomUnary .
