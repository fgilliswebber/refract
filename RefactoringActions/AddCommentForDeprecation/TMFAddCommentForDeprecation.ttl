@prefix fract: <https://w3id.org/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix uct: <https://example.org/uct#> .

fract:tmf_AddCommentForDeprecation a fract:Manifest ;
    fract:transformationType fract:OntologyRefactoringProcess ;
    fract:transformationSource <https://example.org/uct> ;
    fract:hasURIRelationshipToSource fract:SameVersionedRelationship ;
    fract:hasAction fract:action_rc4_1 .

fract:action_rc4_1 a fract:DeprecateClassWithSuccessor ;
    fract:hasAction fract:action_rc4_1a ;
    fract:hasAction fract:action_rc4_1b ;
    fract:hasAction fract:action_rc4_1c ;
    dash:shape shape:ShapeDeprecateClassWithSuccessor .

fract:action_rc4_1a a fract:DeprecateClass ;
    fract:sourceNode uct:SchoolOfLibraryStudies ;
    fract:actionSequence 1 ;
    dash:shape shape:ShapeDeprecateClass .

fract:action_rc4_1b a fract:AddClass ;
    fract:targetIdentifier uct:DepartmentOfKnowledgeAndInformationStewardship ;
    fract:targetParent uct:HumanitiesFaculty ;
    fract:targetLabel "Department of Knowledge and Information Stewardship" ;
    fract:targetLanguageTag "en" ;
    fract:actionSequence 2 ;
    dash:shape shape:ShapeAddClass .

fract:action_rc4_1c a fract:AddCommentForDeprecation ;
    fract:sourceNode uct:SchoolOfLibraryStudies ;
    fract:actionSequence 3 ;
    dash:shape shape:ShapeAddCommentForDeprecation .
