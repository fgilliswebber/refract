@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix ref: <http://semanticweb.tools/ont/refract#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

shape:ShapeAddCommentForDeprecation
    a sh:NodeShape ;
    sh:targetClass ref:AddCommentForDeprecation ;
    sh:property [
        sh:path ref:sourceNode ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path ref:targetAnnotation ;
        sh:nodeKind sh:IRI ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path ref:targetAnnotationValue ;
        sh:datatype xsd:string ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path ref:targetLanguageTag ;
        sh:datatype xsd:string ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path ref:includeSeeAlso ;
        sh:datatype xsd:string ;
        sh:in ("true" "false") ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
    ] .