@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix ref: <https://semanticweb.tools/ont/refract#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

shape:ShapeAddCommentForDeprecation
    a sh:NodeShape ;
    rdfs:label "Shape Add Comment For Deprecation" ;
    rdfs:comment "A shapes graph for validating an 'Add comment for deprecation' refactoring action in a Transformation Manifest File." ;
    sh:targetClass ref:AddCommentForDeprecation ;
    sh:property [
        sh:path ref:sourceNode ;
        sh:name "source node" ;
        sh:description "The URI of an ontology element that already exists in the source ontology and is referenced by a refactoring action." ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path ref:targetAnnotation ;
        sh:name "target annotation" ;
        sh:description "The URI of an annotation property to be added to an ontology element as part of a refactoring action." ;
        sh:nodeKind sh:IRI ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path ref:targetAnnotationValue ;
        sh:name "target annotation value" ;
        sh:description "The value of an annotation to be added to an ontology element as part of a refactoring action, expressed as a plain string." ;
        sh:datatype xsd:string ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path ref:targetLanguageTag ;
        sh:name "target language tag" ;
        sh:description "A language tag expressed as a plain string, conforming to ISO 639 or BCP 47 (e.g. \"en-za\", \"fr\")." ;
        sh:datatype xsd:string ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path ref:includeSeeAlso ;
        sh:name "include 'see also'" ;
        sh:description "Specifies whether the algorithm should add an rdfs:seeAlso reference to the successor class on the deprecated class. Accepts \"true\" or \"false\". If omitted, defaults to \"true\"." ;
        sh:datatype xsd:string ;
        sh:in ("true" "false") ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
    ] .
