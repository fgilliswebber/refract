@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix fract: <https://w3id.org/refract#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

shape:ShapeAddPropertyRestriction
    a sh:NodeShape ;
    rdfs:label "Shape Add Property Restriction" ;
    rdfs:comment "A shapes graph for validating an 'Add property restriction' refactoring action in a Transformation Manifest File." ;
    sh:targetClass fract:AddPropertyRestriction ;
    sh:or (
        [ sh:property [ sh:path fract:sourceNode ; sh:name "source node" ; sh:description "The URI of an ontology element that already exists in the source ontology and is referenced by a refactoring action." ; sh:nodeKind sh:IRI ; sh:minCount 1 ; sh:maxCount 1 ; ] ]
        [ sh:property [ sh:path fract:targetNode ; sh:name "target node" ; sh:description "The URI of an ontology element that already exists in the target ontology, or has been created during the transformation process, and is then referenced by a refactoring action during the same transformation process." ; sh:nodeKind sh:IRI ; sh:minCount 1 ; sh:maxCount 1 ; ] ]
    ) ;
    sh:property [
        sh:path fract:targetObject ;
        sh:name "target object" ;
        sh:description "The URI of the property used in a refactoring action, for example the property of a restriction, axiom, or instance property assertion." ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path fract:targetObjectValue ;
        sh:name "target object value" ;
        sh:description "The URI of the value used in a refactoring action, for example the filler class of a restriction or the value of an instance property assertion." ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path fract:restrictionType ;
        sh:name "restriction type" ;
        sh:description "Specifies the type of restriction to be added as part of a refactoring action. The value must be either owl:someValuesFrom (existential restriction) or owl:allValuesFrom (universal restriction)." ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:in (owl:someValuesFrom owl:allValuesFrom) ;
    ] ;
    sh:property [
        sh:path fract:propertyType ;
        sh:name "property type" ;
        sh:description "Specifies the type of property used in a refactoring action. The value must be either owl:ObjectProperty or owl:DatatypeProperty." ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:in (owl:ObjectProperty owl:DatatypeProperty) ;
    ] .
