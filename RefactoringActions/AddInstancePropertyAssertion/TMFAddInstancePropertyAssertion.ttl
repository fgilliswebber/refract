@prefix fract: <https://w3id.org/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ex: <http://example.org/> .

fract:tmf_AddInstancePropertyAssertion a fract:Manifest ;
    fract:transformationType fract:OntologyEvolutionProcess ;
    fract:transformationSource <http://example.org/ontology> ;
    fract:hasURIRelationshipToSource fract:SameVersioned ;
    fract:hasAction fract:action_AddInstancePropertyAssertion_1 .

fract:action_AddInstancePropertyAssertion_1 a fract:AddInstancePropertyAssertion ;
    fract:targetNode ex:PfizerBioNTech ;
    fract:targetObject ex:hasManufacturer ;
    fract:targetObjectValue ex:PfizerInc ;
    fract:propertyType owl:ObjectProperty ;
    dash:shape shape:ShapeAddInstancePropertyAssertion .
