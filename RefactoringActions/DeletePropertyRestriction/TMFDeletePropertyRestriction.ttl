@prefix fract: <https://w3id.org/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix mar: <https://example.org/marine#> .
@prefix marnz: <https://example.org/marine/nz#> .

fract:tmf_DeletePropertyRestriction a fract:Manifest ;
    fract:transformationType fract:OntologyLocalisationProcess ;
    fract:transformationSource <https://example.org/marine> ;
    fract:hasURIRelationshipToSource fract:SameVersionedRelationship ;
    fract:hasAction fract:action_DeletePropertyRestriction_1 .

fract:action_DeletePropertyRestriction_1 a fract:DeletePropertyRestriction ;
    fract:sourceNode mar:Whale ;
    fract:targetObject marnz:hasGuardian ;
    fract:targetObjectValue mar:Guardian ;
    fract:restrictionType owl:someValuesFrom ;
    dash:shape shape:ShapeDeletePropertyRestriction .
