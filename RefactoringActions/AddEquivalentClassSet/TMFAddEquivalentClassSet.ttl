@prefix fract: <https://w3id.org/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix efo: <http://www.ebi.ac.uk/efo/> .
@prefix ex: <https://example.org/efo/> .

fract:tmf_AddEquivalentClassSet a fract:Manifest ;
    fract:transformationType fract:OntologyEvolutionProcess ;
    fract:transformationSource <http://www.ebi.ac.uk/efo/> ;
    fract:hasURIRelationshipToSource fract:SameVersionedRelationship ;
    fract:hasAction fract:action_AddEquivalentClassSet_1 .

fract:action_AddEquivalentClassSet_1 a fract:AddEquivalentClassSet ;
    fract:targetNode ex:DistributedIntelligence ;
    fract:targetMembers ( efo:EFO_0004337 ex:ArtificialIntelligence ) ;
    fract:setType owl:unionOf ;
    dash:shape shape:ShapeAddEquivalentClassSet .
