@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix fract: <https://w3id.org/refract#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

shape:ShapeAddSubPropertyChainOf
    a sh:NodeShape ;
    rdfs:label "Shape Add Sub-Property Chain Axiom" ;
    rdfs:comment "A shapes graph for validating an 'Add sub-property chain axiom' refactoring action in a Transformation Manifest File." ;
    sh:targetClass fract:AddSubPropertyChainOf ;
    sh:property [
        sh:path fract:sourceNode ;
        sh:name "source node" ;
        sh:description "The URI of an ontology element that already exists in the source ontology and is referenced by a refactoring action." ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path fract:targetMembers ;
        sh:name "target members" ;
        sh:description "A list of URIs representing the members of an ordered or unordered group used in a refactoring action, for example the classes in a union or intersection, or the properties in a sub-property chain." ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:minCount 1 ;
    ] .
