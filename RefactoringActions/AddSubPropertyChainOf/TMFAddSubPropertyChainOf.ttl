@prefix fract: <https://w3id.org/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix ex: <http://example.org/ontology#> .

fract:tmf_AddSubPropertyChainOf a fract:Manifest ;
    fract:transformationType fract:OntologyRefactoringProcess ;
    fract:transformationSource <http://example.org/ontology> ;
    fract:hasURIRelationshipToSource fract:SameVersioned ;
    fract:hasAction fract:action_AddSubPropertyChainOf_1 .

fract:action_AddSubPropertyChainOf_1 a fract:AddSubPropertyChainOf ;
    fract:sourceNode ex:hasLegalGuardian ;
    fract:targetMembers ( ex:hasGuardian ex:hasLegalRepresentative ) ;
    dash:shape shape:ShapeAddSubPropertyChainOf .
