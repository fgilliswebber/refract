@prefix fract: <https://w3id.org/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix ex: <http://example.org/ontology#> .

fract:tmf_AddAnnotationProperty a fract:Manifest ;
    fract:transformationType fract:OntologyRefactoringProcess ;
    fract:transformationSource <http://example.org/ontology> ;
    fract:hasURIRelationshipToSource fract:SameVersionedRelationship ;
    fract:hasAction fract:action_AddAnnotationProperty_1 .

fract:action_AddAnnotationProperty_1 a fract:AddAnnotationProperty ;
    fract:targetIdentifier ex:hasLocalName ;
    fract:targetParent ex:hasName ;
    fract:targetLabel "has local name" ;
    fract:targetLanguageTag "en" ;
    dash:shape shape:ShapeAddAnnotationProperty .
