@prefix fract: <https://w3id.org/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix sweet: <http://sweetontology.net/realmHydroBody/> .

fract:tmf_DeleteSuperclassAssertion a fract:Manifest ;
    fract:transformationType fract:OntologyRefactoringProcess ;
    fract:transformationSource <http://sweetontology.net/realmHydroBody> ;
    fract:hasURIRelationshipToSource fract:SameVersionedRelationship ;
    fract:hasAction fract:action_DeleteSuperclassAssertion_1 .

fract:action_DeleteSuperclassAssertion_1 a fract:DeleteSuperclassAssertion ;
    fract:sourceNode sweet:River ;
    fract:targetParent sweet:NaturalWaterBody ;
    dash:shape shape:ShapeDeleteSuperclassAssertion .
