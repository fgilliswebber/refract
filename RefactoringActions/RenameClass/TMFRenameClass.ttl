@prefix fract: <https://w3id.org/refract#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix edam: <http://edamontology.org/> .

fract:tmf_RenameClass a fract:Manifest ;
    fract:transformationType fract:OntologyRefactoringProcess ;
    fract:transformationSource <http://edamontology.org/> ;
    fract:hasURIRelationshipToSource fract:SameVersioned ;
    fract:hasAction fract:action_RenameClass_1 .

fract:action_RenameClass_1 a fract:RenameClass ;
    fract:sourceNode edam:operation_2928 ;
    fract:targetIdentifier edam:operationAlignment ;
    fract:targetLabel "Alignment" ;
    fract:targetLanguageTag "en" ;
    dash:shape shape:ShapeRenameClass .
