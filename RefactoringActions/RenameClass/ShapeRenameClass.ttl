@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix fract: <https://w3id.org/refract#> .
@prefix shape: <https://semanticweb.tools/rdf/shapes/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

shape:ShapeRenameClass
    a sh:NodeShape ;
    rdfs:label "Shape Rename Class" ;
    rdfs:comment "A shapes graph for validating a 'Rename class' refactoring action in a Transformation Manifest File." ;
    sh:targetClass fract:RenameClass ;
    sh:property [
        sh:path fract:sourceNode ;
        sh:name "source node" ;
        sh:description "The URI of an ontology element that already exists in the source ontology and is referenced by a refactoring action." ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path fract:targetIdentifier ;
        sh:name "target identifier" ;
        sh:description "The URI (or fragment identifier) of an ontology element. This parameter is used when the element does not yet exist in the target ontology, for example when creating a new element. It is also used to specify the new URI when renaming an existing element." ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path fract:targetLabel ;
        sh:name "target label" ;
        sh:description "A plain string label for an ontology element that is to be created by a refactoring action. The language of the label is specified by 'target language tag'. To add additional language-tagged strings, use the annotation action 'Add annotation - lang string'." ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path fract:targetLanguageTag ;
        sh:name "target language tag" ;
        sh:description "A language tag expressed as a plain string, conforming to ISO 639 or BCP 47 (e.g. \"en-za\", \"fr\"). For add actions, this specifies the language tag of the new annotation value or label. For change annotation actions, this is used to identify the specific annotation to be changed where more than one annotation exists for the same annotation property; it is not used to change the language tag itself. To change a language tag, use 'target language tag new'." ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path fract:checkForAssertion ;
        sh:name "check for assertion" ;
        sh:description "Specifies the behaviour of the transformation algorithm when existing assertions are found during pre-processing for an element that is to be deleted. The value must be an instance of 'Algorithm check - assertion'. If this parameter is omitted, the algorithm defaults to 'If true - stop'." ;
        sh:in ( fract:IfTrueDelete fract:IfTrueIgnore fract:IfTrueStop ) ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
    ] .
